# Laravel API base — MUST include path /api/v1 (no trailing slash required; code normalizes slashes).
#
# Local Laravel:
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
#
# Production (same app as admin panel):
# NEXT_PUBLIC_API_BASE_URL=https://admin.newcarpal.com/api/v1
#
# Server CORS: on admin Laravel .env set CORS_ALLOWED_ORIGINS to include every storefront origin, e.g.
#   https://newcarpal.com,https://www.newcarpal.com,http://localhost:3000
# Then: php artisan optimize:clear
#
# Optional — absolute site URL for Open Graph / metadataBase (PWA install prompts). Example:
# NEXT_PUBLIC_SITE_URL=https://newcarpal.com
#
# Optional — full-width background for home "New arrivals" section (block-bg-01). Example:
# NEXT_PUBLIC_HOME_NEW_ARRIVAL_BG=/images/home-new-arrival-bg.jpg
#
# Localization: all storefront requests send X-localization: ar | en (lib/api.ts + lib/client-api.ts).
#
# Optional smoke test:
#   node scripts/verify-api-localization.mjs
NEXT_PUBLIC_API_BASE_URL=

# If admin.newcarpal.com serves an incomplete TLS certificate chain (Node.js throws
# "UNABLE_TO_VERIFY_LEAF_SIGNATURE" when fetching server-side), add this workaround.
# Remove once the Laravel server is configured to send the full certificate chain.
# NODE_TLS_REJECT_UNAUTHORIZED=0
