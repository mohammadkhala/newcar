# Laravel API base — MUST include path /api/v1 (no trailing slash required; code normalizes slashes).
#
# Local Laravel:
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
#
# Production (same app as admin panel):
# NEXT_PUBLIC_API_BASE_URL=https://admin.newcarpal.com/api/v1
#
# Server CORS: on admin Laravel .env set CORS_ALLOWED_ORIGINS to include every storefront origin, e.g.
#   https://newcarpal.com,https://www.newcarpal.com,http://localhost:3000
# Then: php artisan optimize:clear
#
# Localization: all storefront requests send X-localization: ar | en (lib/api.ts + lib/client-api.ts).
#
# Optional smoke test:
#   node scripts/verify-api-localization.mjs
NEXT_PUBLIC_API_BASE_URL=
